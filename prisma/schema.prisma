// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model for authentication and profile
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  profilePic  String?
  firebaseUid String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  pomodoroLogs    PomodoroLog[]
  tags            Tag[]
  flashcards      Flashcard[]
  quizzes         Quiz[]
  analytics       Analytics[]
  sourceMaterials SourceMaterial[]

  @@index([firebaseUid])
  @@map("users")
}

// User-defined tags for categorizing sessions
model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String // Hex color code
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pomodoroLogs PomodoroLog[]

  @@unique([userId, name])
  @@map("tags")
}

// Focus session tracking
model PomodoroLog {
  id                String    @id @default(cuid())
  duration          Int // in minutes
  focusScore        Int? // 1-10 rating
  notes             String?
  sessionType       String    @default("POMODORO") // POMODORO or STOPWATCH
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  flashcardGrouping String? // Link to flashcard grouping for study material tracking
  quizId            String? // Link to quiz for study material tracking

  // Relations
  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tagId  String?
  tag    Tag?    @relation(fields: [tagId], references: [id], onDelete: SetNull)
  quiz   Quiz?   @relation(fields: [quizId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([flashcardGrouping])
  @@index([quizId])
  @@map("pomodoro_logs")
}

// Source materials (PDFs, documents) uploaded by users
model SourceMaterial {
  id            String    @id @default(cuid())
  fileName      String
  fileUrl       String
  fileSize      Int // Size in bytes
  mimeType      String
  extractedText String? // OCR/extracted content
  tags          String[] // Custom tags for categorization
  uploadedAt    DateTime  @default(now())
  processedAt   DateTime? // When OCR/AI processing completed

  // Relations
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]
  quizzes    Quiz[]

  @@map("source_materials")
}

// Flashcards generated from uploaded materials
model Flashcard {
  id           String    @id @default(cuid())
  title        String
  question     String
  answer       String
  grouping     String? // for organizing related flashcards
  difficulty   Int       @default(1) // 1-5 scale
  tags         String[] // Custom tags for categorization
  reviewCount  Int       @default(0)
  lastReviewed DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceMaterialId String?
  sourceMaterial   SourceMaterial? @relation(fields: [sourceMaterialId], references: [id], onDelete: SetNull)

  @@map("flashcards")
}

// Quiz sets containing multiple questions
model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  grouping    String? // for organizing related quizzes
  difficulty  Int      @default(1) // 1-5 scale
  tags        String[] // Custom tags for categorization
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceMaterialId String?
  sourceMaterial   SourceMaterial? @relation(fields: [sourceMaterialId], references: [id], onDelete: SetNull)
  questions        QuizQuestion[]
  attempts         QuizAttempt[]
  pomodoroLogs     PomodoroLog[]

  @@map("quizzes")
}

// Individual questions within a quiz
model QuizQuestion {
  id            String   @id @default(cuid())
  questionText  String
  options       Json // JSON array of options
  correctAnswer String
  explanation   String?
  order         Int // Question order within quiz
  createdAt     DateTime @default(now())

  // Relations
  quizId   String
  quiz     Quiz                  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  attempts QuizQuestionAttempt[]

  @@map("quiz_questions")
}

// Track quiz attempts (entire quiz sessions)
model QuizAttempt {
  id               String    @id @default(cuid())
  score            Float // Percentage score (0.0 - 100.0)
  totalQuestions   Int
  correctAnswers   Int
  timeSpent        Int? // Total time in seconds
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  weakAreaAnalysis Json? // Stored AI analysis

  // Relations
  quizId           String
  quiz             Quiz                  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionAttempts QuizQuestionAttempt[]

  @@map("quiz_attempts")
}

// Track individual question attempts within a quiz session
model QuizQuestionAttempt {
  id             String   @id @default(cuid())
  selectedAnswer String
  isCorrect      Boolean
  timeSpent      Int? // Time spent on this question in seconds
  attemptedAt    DateTime @default(now())

  // Relations
  quizAttemptId  String
  quizAttempt    QuizAttempt  @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  quizQuestionId String
  quizQuestion   QuizQuestion @relation(fields: [quizQuestionId], references: [id], onDelete: Cascade)

  @@map("quiz_question_attempts")
}

// Daily analytics tracking (flashcard reviews, quiz completions)
model Analytics {
  id                    String   @id @default(cuid())
  date                  DateTime @default(now()) @db.Date
  tasksCompleted        Int      @default(0)
  pomodoroSessions      Int      @default(0)
  focusHours            Float    @default(0)
  aiSuggestionsAccepted Int      @default(0)
  aiSuggestionsRejected Int      @default(0)
  flashcardsReviewed    Int      @default(0)
  quizzesCompleted      Int      @default(0)

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("analytics")
}
